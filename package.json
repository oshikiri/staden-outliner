{
  "name": "staden-outliner",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev:api": "bun run serve:api",
    "dev:web": "bun run build:web && bun run serve:web",
    "build:api:binary": "bun build --compile --compile-autoload-tsconfig --compile-autoload-package-json src/server/api-entry.ts --outfile dist/staden-api",
    "build:web": "bun run src/server/build-web.ts",
    "format": "prettier --write . --list-different",
    "format:check": "prettier --check .",
    "verify": "bun run format:check && bun run lint && bun run build:web && bun run test:unit",
    "start:api": "bun run serve:api",
    "start:api:binary": "./dist/staden-api",
    "start:web": "bun run serve:web",
    "serve:api": "bun src/server/api-entry.ts",
    "serve:web": "bun src/server/web-entry.ts",
    "serve:web:preview": "bun run serve:web",
    "lint": "eslint src eslint.config.mjs postcss.config.mjs",
    "test-coverage": "bun test src --preload ./test/setup.ts --coverage",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "test:unit": "bun test src --preload ./test/setup.ts",
    "test": "bun run test:unit && bun run test:e2e"
  },
  "dependencies": {
    "highlight.js": "11.11.1",
    "hono": "4.12.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router-dom": "7.14.0"
  },
  "devDependencies": {
    "@eslint/compat": "2.0.3",
    "@playwright/test": "1.58.2",
    "@tailwindcss/postcss": "4.2.1",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "better-sqlite3": "12.6.2",
    "bun-types": "1.3.12",
    "eslint": "10.0.3",
    "postcss": "8.5.8",
    "prettier": "3.8.1",
    "tailwindcss": "4.2.2",
    "typescript": "5.9.3",
    "zustand": "5.0.11"
  }
}
