{
  "name": "staden-outliner",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "engines": {
    "bun": ">=1.3.12"
  },
  "scripts": {
    "dev": "bun run src/server/dev.ts",
    "reset-db": "bun run src/server/reset-db.ts",
    "build": "bun run src/server/build-web.ts && bun build --compile --compile-autoload-tsconfig --compile-autoload-package-json src/server/web-binary-entry.ts --outfile dist/staden",
    "format": "prettier --write . --list-different",
    "format:check": "prettier --check .",
    "typecheck": "tsc -p tsconfig.client.json --noEmit && tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.root.json --noEmit",
    "verify": "bun run format:check && bun run lint && bun run typecheck && bun run build && bun run test:unit",
    "lint": "eslint src eslint.config.ts",
    "test-coverage": "bun test src --coverage --max-concurrency=1",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "test:unit": "bun test src",
    "test": "bun run test:unit && bun run test:e2e"
  },
  "dependencies": {
    "@observablehq/plot": "0.6.17",
    "hono": "4.12.14",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-router-dom": "7.14.2",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "4.2.4",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.58.2",
    "@typescript-eslint/parser": "8.58.2",
    "bun-types": "1.3.12",
    "eslint": "10.2.1",
    "postcss": "8.5.10",
    "prettier": "3.8.3",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3"
  }
}
